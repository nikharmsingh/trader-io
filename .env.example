# ─────────────────────────────────────────────
#  TRADER.IO — Environment Configuration
# ─────────────────────────────────────────────

# === Kafka / Redpanda ===
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRADES=raw.trades
KAFKA_TOPIC_CANDLES=processed.candles
KAFKA_TOPIC_INDICATORS=processed.indicators
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=trader-io-consumers
KAFKA_NUM_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# === Data Source ===
DATA_SOURCE=mock                    # mock | binance | zerodha
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_secret_here
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,ADAUSDT
MOCK_TICK_INTERVAL_MS=500          # Tick frequency for mock generator

# === MinIO (S3-compatible) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RAW=raw-market-data
MINIO_BUCKET_PROCESSED=processed-market-data
MINIO_USE_SSL=false

# === ClickHouse ===
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse123
CLICKHOUSE_DATABASE=trader_io

# === Airflow ===
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=false
AIRFLOW__CORE__LOAD_EXAMPLES=false

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8501,http://dashboard:8501

# === Streamlit Dashboard ===
API_BASE_URL=http://api:8000
DASHBOARD_REFRESH_INTERVAL=5      # seconds

# === Alerting ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
ALERT_RSI_OVERBOUGHT=70
ALERT_RSI_OVERSOLD=30
ALERT_ENGINE_ENABLED=true

# === Monitoring ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json                    # json | text
