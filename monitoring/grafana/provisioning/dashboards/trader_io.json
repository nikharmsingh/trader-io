{
  "id": 2,
  "panels": [
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status_code}}",
          "refId": "A"
        }
      ],
      "title": "API Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "API p99 Latency (ms)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (topic) (kafka_topic_partition_current_offset{topic=~\"raw.trades|processed.candles|processed.indicators|alerts\"})",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Kafka \u2014 Topic Partition Offsets (messages)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (topic) (kafka_topic_partition_current_offset{topic=~\"raw.trades|processed.candles|processed.indicators|alerts\"} - kafka_topic_partition_oldest_offset{topic=~\"raw.trades|processed.candles|processed.indicators|alerts\"})",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Kafka \u2014 Messages in Topics",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(kafka_topic_partition_current_offset{topic=\"raw.trades\"}[1m])",
          "legendFormat": "partition {{partition}}",
          "refId": "A"
        }
      ],
      "title": "Kafka \u2014 Messages / sec (raw.trades)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_in_flight)",
          "refId": "A"
        }
      ],
      "title": "API In-Flight Requests",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "title": "API Total Requests (last 5m)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 20
      },
      "id": 8,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "API Errors (5xx last 5m)",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 20
      },
      "id": 9,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_brokers",
          "refId": "A"
        }
      ],
      "title": "Kafka Brokers Online",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 10,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "title": "System CPU Usage (%)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 11,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "title": "System Memory Usage (%)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 32
      },
      "id": 12,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT count() AS value FROM candles_1m",
          "refId": "A"
        }
      ],
      "title": "ClickHouse \u2014 Rows in candles_1m",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 32
      },
      "id": 13,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT count() AS value FROM indicators",
          "refId": "A"
        }
      ],
      "title": "ClickHouse \u2014 Rows in indicators",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 32
      },
      "id": 14,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT count() AS value FROM trades WHERE toDateTime(event_time/1000) >= now() - INTERVAL 5 MINUTE",
          "refId": "A"
        }
      ],
      "title": "ClickHouse \u2014 Trades (last 5 min)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 120
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 32
      },
      "id": 15,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT toFloat64(max(dateDiff('second', toDateTime(event_time/1000), now()))) AS value FROM trades",
          "refId": "A"
        }
      ],
      "title": "ClickHouse \u2014 Data Lag (seconds)",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "id": 16,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT symbol, sum(quantity) AS volume FROM trades WHERE toDateTime(event_time/1000) >= now() - INTERVAL 1 HOUR GROUP BY symbol ORDER BY volume DESC",
          "refId": "A"
        }
      ],
      "title": "ClickHouse \u2014 Trade Volume by Symbol (last 1h)",
      "type": "barchart"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "id": 17,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(toDateTime(open_time/1000)) AS time, count() AS candles FROM candles_1m WHERE toDateTime(open_time/1000) >= now() - INTERVAL 30 MINUTE GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "ClickHouse \u2014 Candles Written per Minute",
      "type": "timeseries"
    }
  ],
