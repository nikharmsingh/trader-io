{
  "title": "Trader.IO — Pipeline Monitoring",
  "uid": "trader-io-main",
  "tags": ["trader-io"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API p99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Kafka Messages Produced / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(trader_messages_produced_total[1m])",
          "legendFormat": "{{symbol}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_consumergroup_lag",
          "legendFormat": "{{consumergroup}} {{topic}} {{partition}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Producer Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(trader_produce_errors_total[5m]))"
        }
      ]
    },
    {
      "id": 6,
      "title": "API In-Flight Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_in_flight)"
        }
      ]
    },
    {
      "id": 7,
      "title": "Produce Latency p50 (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(trader_produce_latency_seconds_bucket[1m])) * 1000"
        }
      ]
    },
    {
      "id": 8,
      "title": "System CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode='idle'}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 9,
      "title": "System Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "id": 10,
      "title": "Spark — Input Rows / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "spark_streaming_inputRowsPerSecond",
          "legendFormat": "{{query_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rows/s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 11,
      "title": "Spark — Batch Duration (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "spark_streaming_batchDuration",
          "legendFormat": "{{query_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 12,
      "title": "ClickHouse — Rows in candles_1m",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT count() AS value FROM candles_1m",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "ClickHouse — Rows in indicators",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT count() AS value FROM indicators",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "ClickHouse — Trades last 5 min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 36 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT count() AS value FROM trades WHERE toDateTime(event_time/1000) >= now() - INTERVAL 5 MINUTE",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "ClickHouse — Data Freshness (max lag seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 36 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT max(dateDiff('second', toDateTime(event_time/1000), now())) AS value FROM trades",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      }
    }
  ]
}
